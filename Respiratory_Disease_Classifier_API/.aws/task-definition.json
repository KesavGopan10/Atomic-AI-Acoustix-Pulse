{
    "family": "respiratory-api-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "respiratory-api-container",
            "image": "REPLACED_BY_GITHUB_ACTIONS",
            "cpu": 512,
            "memory": 1024,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "AI_PROVIDER",
                    "value": "groq"
                },
                {
                    "name": "GROQ_MODEL",
                    "value": "meta-llama/llama-4-scout-17b-16e-instruct"
                }
            ],
            "secrets": [
                {
                    "name": "GROQ_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:YOUR_ACCOUNT_ID:secret:GROQ_API_KEY"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/respiratory-api",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskRole"
}